{{ 'flickity.min.css' | asset_url | stylesheet_tag }}
{{ 'flickity.pkgd.min.js' | asset_url | script_tag }}

<style>
  #shopify-section-{{ section.id }} {
    --page-margin: 0px !important;
    grid-template-columns: 100% !important;
    display: block !important;
  }
  #shopify-section-{{ section.id }} > * {
    grid-column: 1 / -1 !important;
    width: 100% !important;
  }
  #shopify-section-{{ section.id }} .product {
  width: 100%; /* Shows exactly one product at a time */
  margin-right: 10px; /* Space between slides */
  text-align: center;
}
#shopify-section-{{ section.id }} .flickity-prev-next-button {
  opacity: 0;
  transition: opacity 0.3s ease;
}

#shopify-section-{{ section.id }} .task1-container:hover .flickity-prev-next-button {
  opacity: 1;
}

</style>
{{ 'task1.css' | asset_url | stylesheet_tag }}

<section class="task1 ">
  <div class="task1-div">
    <div class="task1-img">
      {% if section.settings.iamge_url != blank %}
        <img src="{{section.settings.iamge_url |  image_url }}" />
      {% else %}
        <img src="{{'default.jpg' |  asset_img_url:'medium'}}" />
      {% endif %}
    </div>
    <div class="task1-container">
      <h1>
        {{ section.settings.heading }}
      </h1>
       <div class="main-carousel" data-flickity='{ "cellAlign": "center", "contain": true, "pageDots": false, "groupCells": false ,"wrapAround":true}'>
      {% for block in section.blocks %}
    {% for product in block.settings.products %}
      <div class="product">
        <div class="product-image">
          {% if product.featured_image != blank %}
            <img src="{{ product.featured_image | image_url: width:300 }}" alt="{{ product.title }}">
          {% else %}
             <img src="{{'default.jpg' |  asset_img_url:'medium'}}" />
          {% endif %}
        </div>
        <h2>{{ product.title | escape }}</h2>
        <p>{{ product.price | money | escape }}</p>
      </div>
    {% endfor %}
  {% endfor %}
    </div>
      <button class="addtocartbtn" >ADD TO CART</button>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "task1",
    "settings": [
      {
        "type": "image_picker",
        "id": "iamge_url",
        "label": "image"
      }, {
        "type": "text",
        "id": "heading",
        "default": "Complete the look",
        "label": "heading"
      }
    ],
    "blocks": [
      {
        "type": "product",
        "name": "products",
        "settings": [
          {
            "type": "product_list",
            "id": "products",
            "label": "selected products"
          } 
        ]
      },
      {
        "type": "hotspot",
        "name":"image hotspot",
        "settings": [
            { "type": "range", 
                "id": "x_pos", 
                "min": 0, 
                "max": 100, 
                "unit": "%", 
                "label": "Horizontal Position", 
                "default": 50 
            },
            { "type": "range", 
                "id": "y_pos", 
                "min": 0, 
                "max": 100, 
                "unit": "%", 
                "label": "Vertical Position", 
                "default": 50 }
        ]
    }
    ],
    "max_blocks": 5,
    "presets": [
      {
        "name": "Task 1 section",
        "blocks": [
            {
            "type":"product"
            }
    ]
      }
    ]
  }

{% endschema %}